          <label>Tuesday:</label>
          <input type="time" id="tue-open">
          <span>to</span>
          <input type="time" id="tue-close">
        </div>
        <div class="day-input">
          <label>Wednesday:</label>
          <input type="time" id="wed-open">
          <span>to</span>
          <input type="time" id="wed-close">
        </div>
        <div class="day-input">
          <label>Thursday:</label>
          <input type="time" id="thu-open">
          <span>to</span>
          <input type="time" id="thu-close">
        </div>
        <div class="day-input">
          <label>Friday:</label>
          <input type="time" id="fri-open">
          <span>to</span>
